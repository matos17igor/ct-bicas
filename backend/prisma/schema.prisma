generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id         String    @id @default(uuid())
  name       String
  email      String    @unique
  password   String
  phone      String?
  role       String    @default("USER")
  isVerified Boolean   @default(false)
  bookings   Booking[]
  tokens     Token[]
  createdAt  DateTime  @default(now())
}

model Token {
  id        String    @id @default(uuid())
  code      String
  type      TokenType
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime  @default(now())
}

enum TokenType {
  VERIFY_EMAIL
  RESET_PASSWORD
}

model Court {
  id       String    @id @default(uuid())
  name     String
  bookings Booking[]
}

model Booking {
  id        String   @id @default(uuid())
  date      DateTime
  startTime DateTime
  endTime   DateTime
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
  courtId   String
  court     Court    @relation(fields: [courtId], references: [id])
  isBlocked Boolean  @default(false)
  reason    String?
}