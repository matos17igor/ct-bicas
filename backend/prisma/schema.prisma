generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String    @id @default(uuid())
  name      String
  email     String    @unique
  password  String
  phone     String?
  role      String    @default("USER")
  bookings  Booking[]
  createdAt DateTime  @default(now())
}

model Court {
  id       String    @id @default(uuid())
  name     String
  bookings Booking[]
}

model Booking {
  id        String   @id @default(uuid())
  date      DateTime
  startTime DateTime
  endTime   DateTime
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
  courtId   String
  court     Court    @relation(fields: [courtId], references: [id])
  isBlocked Boolean  @default(false)
  reason    String?
}